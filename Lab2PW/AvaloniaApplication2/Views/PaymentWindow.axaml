<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AvaloniaApplication2.Views.PaymentWindow"
        Title="Płatność"
        Width="300" Height="300"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock Name="AmountText" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
        
        <TextBlock Text="Metoda płatności:"/>
        <RadioButton Name="CardRadio" Content="Karta" IsChecked="True"/>
        <RadioButton Name="CashRadio" Content="Gotówka"/>
        <RadioButton Name="BlikRadio" Content="BLIK"/>

        <Button Name="PayBtn" Content="Zapłać teraz" HorizontalAlignment="Center" Margin="0,20,0,0"/>
    </StackPanel>
</Window>
