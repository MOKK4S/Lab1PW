<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Lab6PW.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="650"
        Width="450" Height="650"
        x:Class="Lab6PW.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Złap Hyraxy - Menu"
        WindowStartupLocation="CenterScreen"
        Background="#ECEFF1">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Margin="40" Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="ZŁAP HYRAXY" 
                       FontSize="42" 
                       FontWeight="ExtraBold" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"
                       Foreground="#263238"/>

            <Button Content="START" 
                    Click="StartGame_Click"
                    Width="250" Height="55"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    FontSize="20" FontWeight="Bold"
                    Background="#43A047" Foreground="White"
                    CornerRadius="10"/>

            <Button Content="USTAWIENIA" 
                    Command="{Binding ToggleSettingsCommand}"
                    Width="250" Height="50"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    FontSize="18" FontWeight="SemiBold"
                    Background="#1E88E5" Foreground="White"
                    CornerRadius="10"/>

            <Button Content="KONIEC" 
                    Command="{Binding ExitCommand}"
                    Width="250" Height="50"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    FontSize="18" FontWeight="SemiBold"
                    Background="#E53935" Foreground="White"
                    CornerRadius="10"/>

            <!-- Settings Panel -->
            <Border IsVisible="{Binding IsSettingsVisible}" 
                    Background="White" 
                    CornerRadius="12" 
                    Padding="20" 
                    Margin="0,10,0,0"
                    BoxShadow="0 4 12 0 #30000000">
                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto">
                    <TextBlock Text="X:" VerticalAlignment="Center" Margin="0,5" Grid.Row="0" Grid.Column="0"/>
                    <NumericUpDown Value="{Binding BoardX}" Minimum="3" Maximum="10" Margin="0,5" Grid.Row="0" Grid.Column="1"/>
                    
                    <TextBlock Text="Y:" VerticalAlignment="Center" Margin="0,5" Grid.Row="1" Grid.Column="0"/>
                    <NumericUpDown Value="{Binding BoardY}" Minimum="3" Maximum="10" Margin="0,5" Grid.Row="1" Grid.Column="1"/>
                    
                    <TextBlock Text="Hyraxy:" VerticalAlignment="Center" Margin="0,5" Grid.Row="2" Grid.Column="0"/>
                    <NumericUpDown Value="{Binding HyraxCount}" Minimum="1" Maximum="6" Margin="0,5" Grid.Row="2" Grid.Column="1"/>
                    
                    <TextBlock Text="Szopy:" VerticalAlignment="Center" Margin="0,5" Grid.Row="3" Grid.Column="0"/>
                    <NumericUpDown Value="{Binding RaccoonCount}" Minimum="2" Maximum="8" Margin="0,5" Grid.Row="3" Grid.Column="1"/>
                    
                    <TextBlock Text="Krokodyle:" VerticalAlignment="Center" Margin="0,5" Grid.Row="4" Grid.Column="0"/>
                    <NumericUpDown Value="{Binding CrocodileCount}" Minimum="0" Maximum="1" Margin="0,5" Grid.Row="4" Grid.Column="1"/>
                </Grid>
            </Border>

            <!-- Score Table -->
            <TextBlock Text="TOP LISTA" FontSize="16" FontWeight="Bold" Margin="0,20,0,0" HorizontalAlignment="Center"/>
            <Border Background="White" CornerRadius="12" Padding="5">
                <ListBox ItemsSource="{Binding Scores}" MaxHeight="150">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Text="{Binding Date, StringFormat='\{0:yyyy-MM-dd HH:mm\}'}" Margin="5"/>
                                <TextBlock Grid.Column="1" Text="{Binding TimeInSeconds, StringFormat='\{0:F2\} s'}" FontWeight="Bold" Margin="15,5,5,5"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
