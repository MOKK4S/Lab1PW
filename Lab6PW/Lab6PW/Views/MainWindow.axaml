<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Lab6PW.ViewModels"
        x:Class="Lab6PW.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="450" Height="680"
        WindowStartupLocation="CenterScreen"
        Background="#CFD8DC">

    <StackPanel Margin="30" Spacing="15">
        <TextBlock Text="ZŁAP HYRAXY" 
                   FontSize="40" FontWeight="Black" 
                   HorizontalAlignment="Center" Foreground="#212121"
                   Margin="0,0,0,20"/>

        <Button Content="START" Click="StartGame_Click"
                Width="200" Height="50" HorizontalAlignment="Center"
                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                Background="#81C784" Foreground="#212121" FontSize="20" FontWeight="Bold"/>

        <Button Content="USTAWIENIA" Command="{Binding ToggleSettingsCommand}"
                Width="200" Height="50" HorizontalAlignment="Center"
                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                Background="#64B5F6" Foreground="#212121" FontSize="18" FontWeight="Bold"/>

        <Button Content="KONIEC" Command="{Binding ExitCommand}"
                Width="200" Height="50" HorizontalAlignment="Center"
                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                Background="#E57373" Foreground="#212121" FontSize="18" FontWeight="Bold"/>

        <!-- Settings -->
        <Border IsVisible="{Binding IsSettingsVisible}" 
                Background="White" CornerRadius="10" Padding="15" Margin="0,10,0,0">
            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <TextBlock Text="Szerokość (X):" Grid.Row="0" Grid.Column="0" Foreground="Black" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding BoardX}" Grid.Row="0" Grid.Column="1" Foreground="Black" Minimum="3" Maximum="10"/>

                <TextBlock Text="Wysokość (Y):" Grid.Row="1" Grid.Column="0" Foreground="Black" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding BoardY}" Grid.Row="1" Grid.Column="1" Foreground="Black" Minimum="3" Maximum="10"/>

                <TextBlock Text="Hyraxy (CEL):" Grid.Row="2" Grid.Column="0" Foreground="Black" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding HyraxCount}" Grid.Row="2" Grid.Column="1" Foreground="Black" Minimum="1" Maximum="6"/>

                <TextBlock Text="Szopy (-1 pkt):" Grid.Row="3" Grid.Column="0" Foreground="Black" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding RaccoonCount}" Grid.Row="3" Grid.Column="1" Foreground="Black" Minimum="2" Maximum="8"/>

                <TextBlock Text="Krokodyle (Koniec):" Grid.Row="4" Grid.Column="0" Foreground="Black" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding CrocodileCount}" Grid.Row="4" Grid.Column="1" Foreground="Black" Minimum="0" Maximum="1"/>
            </Grid>
        </Border>

        <TextBlock Text="WYNIKI" FontSize="16" FontWeight="Bold" Foreground="#212121" HorizontalAlignment="Center" Margin="0,15,0,0"/>
        <ListBox ItemsSource="{Binding Scores}" MaxHeight="120" Background="White" Foreground="Black" CornerRadius="5"/>
    </StackPanel>
</Window>
