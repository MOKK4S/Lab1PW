<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Lab6PW.ViewModels"
        x:Class="Lab6PW.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Złap Hyraxy" Width="400" Height="500">
    <StackPanel Margin="20">
        <TextBlock Text="ZŁAP HYRAXY" FontSize="20" HorizontalAlignment="Center"/>
        <Button Content="START" Click="StartGame_Click" HorizontalAlignment="Center" Width="150"/>
        <Button Content="USTAWIENIA" Command="{Binding ToggleSettingsCommand}" HorizontalAlignment="Center" Width="150"/>
        <Button Content="KONIEC" Command="{Binding ExitCommand}" HorizontalAlignment="Center" Width="150"/>
        <StackPanel IsVisible="{Binding IsSettingsVisible}">
            <NumericUpDown Value="{Binding BoardX}"/>
            <NumericUpDown Value="{Binding BoardY}"/>
        </StackPanel>
    </ListBox ItemsSource="{Binding Scores}"/>
    </StackPanel>
</Window>
